# ── ArubaCloud credentials ────────────────────────────────────────────────────
arubacloud_client_id     = "your-oauth2-client-id"
arubacloud_client_secret = "your-oauth2-client-secret"

# ── SSH access ────────────────────────────────────────────────────────────────
ssh_public_key = "ssh-ed25519 AAAA... user@host"

# Restrict SSH to your IP in production (highly recommended)
# ssh_cidr = "203.0.113.42/32"

# ── VPN configuration ────────────────────────────────────────────────────────
# vpn_port           = 51820
# vpn_server_address = "10.8.0.1/24"
# dns_servers        = ["1.1.1.1", "1.0.0.1"]

# ── Infrastructure (optional overrides) ───────────────────────────────────────
# app_name       = "wg"
# environment    = "prod"
# location       = "ITBG-Bergamo"
# zone           = "ITBG-1"
# vm_flavor      = "CSO2A4"
# vm_disk_size_gb = 20
# billing_period = "Hour"
