# ── ArubaCloud credentials ────────────────────────────────────────────────────
arubacloud_client_id     = "your-oauth2-client-id"
arubacloud_client_secret = "your-oauth2-client-secret"

# ── SSH access ────────────────────────────────────────────────────────────────
ssh_public_key = "ssh-ed25519 AAAA... user@host"
# ssh_cidr     = "203.0.113.42/32"
# admin_cidr   = "203.0.113.42/32"
# syslog_cidr  = "10.0.0.0/8"

# ── Graylog ───────────────────────────────────────────────────────────────────
graylog_admin_password = "change-me-strong"
# Generate with: pwgen -N 1 -s 96
graylog_secret         = "change-me-96-char-minimum-random-secret-string-here-for-graylog-password-signing"

# ── Infrastructure (optional overrides) ───────────────────────────────────────
# app_name        = "gl"
# environment     = "prod"
# location        = "ITBG-Bergamo"
# zone            = "ITBG-1"
# vm_flavor       = "CSO4A8"    # 8 GB RAM minimum
# vm_disk_size_gb = 100
# billing_period  = "Hour"
# graylog_version = "6"
