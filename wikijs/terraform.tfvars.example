# ── ArubaCloud credentials ────────────────────────────────────────────────────
arubacloud_client_id     = "your-oauth2-client-id"
arubacloud_client_secret = "your-oauth2-client-secret"

# ── SSH access ────────────────────────────────────────────────────────────────
ssh_public_key = "ssh-ed25519 AAAA... user@host"
# ssh_cidr     = "203.0.113.42/32"

# ── Database ──────────────────────────────────────────────────────────────────
db_password = "change-me-min-16-chars-no-newlines"
# dbaas_flavor  = "DBO2A8"
# db_storage_gb = 20

# ── Wiki.js ───────────────────────────────────────────────────────────────────
# wikijs_version = "2"   # or "2.5.303" for a specific patch release

# ── Infrastructure (optional overrides) ───────────────────────────────────────
# app_name        = "wikijs"
# environment     = "prod"
# location        = "ITBG-Bergamo"
# zone            = "ITBG-1"
# vm_flavor       = "CSO2A4"
# vm_disk_size_gb = 20
# billing_period  = "Hour"
