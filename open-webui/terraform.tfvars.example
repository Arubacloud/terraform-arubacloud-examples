# ── ArubaCloud credentials ────────────────────────────────────────────────────
arubacloud_client_id     = "your-oauth2-client-id"
arubacloud_client_secret = "your-oauth2-client-secret"

# ── SSH access ────────────────────────────────────────────────────────────────
ssh_public_key = "ssh-ed25519 AAAA... user@host"
# ssh_cidr     = "203.0.113.42/32"

# ── Open WebUI ────────────────────────────────────────────────────────────────
# Point to an Ollama instance (see the ollama example)
# ollama_base_url = "http://10.0.0.10:11434"

# Or use OpenAI directly
# openai_api_key = "sk-..."

# Session secret (auto-generated if empty)
# webui_secret_key = "your-32-char-minimum-secret-key"

# ── Infrastructure (optional overrides) ───────────────────────────────────────
# app_name           = "owui"
# environment        = "prod"
# location           = "ITBG-Bergamo"
# zone               = "ITBG-1"
# vm_flavor          = "CSO2A4"
# vm_disk_size_gb    = 20
# billing_period     = "Hour"
# open_webui_version = "main"
