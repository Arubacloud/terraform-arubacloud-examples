# ── ArubaCloud credentials ────────────────────────────────────────────────────
arubacloud_client_id     = "your-oauth2-client-id"
arubacloud_client_secret = "your-oauth2-client-secret"

# ── SSH access ────────────────────────────────────────────────────────────────
ssh_public_key = "ssh-ed25519 AAAA... user@host"
# ssh_cidr     = "203.0.113.42/32"

# ── Authentik ─────────────────────────────────────────────────────────────────
pg_password          = "change-me-pg-password"
# Generate with: openssl rand -hex 32
authentik_secret_key = "change-me-32-char-minimum-secret-key-here-000000"

# ── Infrastructure (optional overrides) ───────────────────────────────────────
# app_name          = "auth"
# environment       = "prod"
# location          = "ITBG-Bergamo"
# zone              = "ITBG-1"
# vm_flavor         = "CSO2A4"
# vm_disk_size_gb   = 20
# billing_period    = "Hour"
# authentik_version = "latest"
