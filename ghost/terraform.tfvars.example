# ── ArubaCloud credentials ────────────────────────────────────────────────────
# Obtain from the ArubaCloud console → API → OAuth2 Clients
arubacloud_client_id     = "your-oauth2-client-id"
arubacloud_client_secret = "your-oauth2-client-secret"

# ── SSH access ────────────────────────────────────────────────────────────────
# Paste the full content of your ~/.ssh/id_rsa.pub or ~/.ssh/id_ed25519.pub
ssh_public_key = "ssh-ed25519 AAAA... user@host"

# Restrict SSH to your IP in production (recommended)
# ssh_cidr = "203.0.113.42/32"

# ── Database ──────────────────────────────────────────────────────────────────
# Use a strong random password (min 16 chars). No newlines.
db_password = "change-me-use-a-strong-password-here"

# ── Ghost ─────────────────────────────────────────────────────────────────────
# Optional: set a domain to enable automatic HTTPS via Let's Encrypt.
# The domain must point to the VM's Elastic IP before terraform apply.
# domain = "blog.example.com"

# ── Infrastructure (optional overrides) ───────────────────────────────────────
# app_name        = "ghost"
# environment     = "prod"
# location        = "ITBG-Bergamo"
# zone            = "ITBG-1"
# vm_flavor       = "CSO2A4"
# vm_disk_size_gb = 30
# dbaas_flavor    = "DBO2A8"
# db_storage_gb   = 20
# billing_period  = "Hour"
