# ── ArubaCloud credentials ────────────────────────────────────────────────────
arubacloud_client_id     = "your-oauth2-client-id"
arubacloud_client_secret = "your-oauth2-client-secret"

# ── SSH access ────────────────────────────────────────────────────────────────
ssh_public_key = "ssh-ed25519 AAAA... user@host"
# ssh_cidr     = "203.0.113.42/32"

# ── CrowdSec ──────────────────────────────────────────────────────────────────
# Get your enrollment key from https://app.crowdsec.net
# enroll_key  = "your-console-enrollment-key"

# Collections to install (add stacks for services you run alongside CrowdSec)
# collections = ["crowdsecurity/linux", "crowdsecurity/sshd", "crowdsecurity/nginx"]

# ── Infrastructure (optional overrides) ───────────────────────────────────────
# app_name        = "cs"
# environment     = "prod"
# location        = "ITBG-Bergamo"
# zone            = "ITBG-1"
# vm_flavor       = "CSO1A2"
# vm_disk_size_gb = 20
# billing_period  = "Hour"
