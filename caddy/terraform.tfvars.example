# ── ArubaCloud credentials ────────────────────────────────────────────────────
arubacloud_client_id     = "your-oauth2-client-id"
arubacloud_client_secret = "your-oauth2-client-secret"

# ── SSH access ────────────────────────────────────────────────────────────────
ssh_public_key = "ssh-ed25519 AAAA... user@host"

# Restrict SSH to your management IP
# ssh_cidr = "203.0.113.42/32"

# ── Caddy / TLS (optional) ────────────────────────────────────────────────────
# Set to enable automatic HTTPS via Let's Encrypt — no certbot needed.
# The DNS A record for the domain must point to the VM's Elastic IP before apply.
# domain = "example.com"

# ── Infrastructure (optional overrides) ───────────────────────────────────────
# app_name        = "caddy"
# environment     = "prod"
# location        = "ITBG-Bergamo"
# zone            = "ITBG-1"
# vm_flavor       = "CSO1A2"
# vm_disk_size_gb = 20
# billing_period  = "Hour"
# web_cidr        = "0.0.0.0/0"
