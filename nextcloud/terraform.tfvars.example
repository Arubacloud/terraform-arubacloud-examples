arubacloud_client_id     = "your-oauth2-client-id"
arubacloud_client_secret = "your-oauth2-client-secret"
ssh_public_key           = "ssh-ed25519 AAAA... user@host"

db_password       = "change-me-strong-database-password-16chars"
nc_admin_password = "change-me-strong-admin-password-16chars"
nc_admin_email    = "admin@example.com"

