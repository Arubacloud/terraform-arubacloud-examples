# ── ArubaCloud credentials ────────────────────────────────────────────────────
arubacloud_client_id     = "your-oauth2-client-id"
arubacloud_client_secret = "your-oauth2-client-secret"

# ── SSH access ────────────────────────────────────────────────────────────────
ssh_public_key = "ssh-ed25519 AAAA... user@host"

# Restrict access to your office or VPN range in production
# ssh_cidr   = "203.0.113.42/32"
# sonar_cidr = "203.0.113.0/24"

# ── Database ──────────────────────────────────────────────────────────────────
db_password = "change-me-use-a-strong-password-here"

# ── SonarQube ─────────────────────────────────────────────────────────────────
# Check https://www.sonarsource.com/products/sonarqube/downloads/ for the latest CE version.
# The version string includes the build number (e.g. "10.7.0.96327").
# sonarqube_version = "10.7.0.96327"

# ── Infrastructure (optional overrides) ───────────────────────────────────────
# app_name        = "sonar"
# environment     = "prod"
# location        = "ITBG-Bergamo"
# zone            = "ITBG-1"
# vm_flavor       = "CSO4A8"
# vm_disk_size_gb = 80
# billing_period  = "Hour"
