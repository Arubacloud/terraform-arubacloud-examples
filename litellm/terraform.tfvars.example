# ── ArubaCloud credentials ────────────────────────────────────────────────────
arubacloud_client_id     = "your-oauth2-client-id"
arubacloud_client_secret = "your-oauth2-client-secret"

# ── SSH access ────────────────────────────────────────────────────────────────
ssh_public_key = "ssh-ed25519 AAAA... user@host"
# ssh_cidr     = "203.0.113.42/32"

# Restrict to your app servers
# api_cidr   = "10.0.0.0/8"

# ── LiteLLM ───────────────────────────────────────────────────────────────────
master_key = "sk-your-master-key"

# Add API keys for the providers you want to use
# openai_api_key    = "sk-..."
# anthropic_api_key = "sk-ant-..."

# Optional: point to an Ollama instance (see the ollama example)
# ollama_base_url = "http://10.0.0.10:11434"

# ── Infrastructure (optional overrides) ───────────────────────────────────────
# app_name        = "llm"
# environment     = "prod"
# location        = "ITBG-Bergamo"
# zone            = "ITBG-1"
# vm_flavor       = "CSO2A4"
# vm_disk_size_gb = 20
# billing_period  = "Hour"
# litellm_version = "main"
