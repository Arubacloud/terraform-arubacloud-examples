# ── ArubaCloud credentials ────────────────────────────────────────────────────
arubacloud_client_id     = "your-oauth2-client-id"
arubacloud_client_secret = "your-oauth2-client-secret"

# ── SSH access ────────────────────────────────────────────────────────────────
ssh_public_key = "ssh-ed25519 AAAA... user@host"
# ssh_cidr   = "203.0.113.42/32"
# admin_cidr = "203.0.113.42/32"  # restrict stats page

# ── HAProxy ───────────────────────────────────────────────────────────────────
stats_password = "change-me-strong"

# Backend servers to load balance (host:port). Leave empty to deploy without backends.
# backends = ["10.0.0.1:80", "10.0.0.2:80"]

# ── Infrastructure (optional overrides) ───────────────────────────────────────
# app_name        = "haproxy"
# environment     = "prod"
# location        = "ITBG-Bergamo"
# zone            = "ITBG-1"
# vm_flavor       = "CSO2A4"
# vm_disk_size_gb = 20
# billing_period  = "Hour"
# web_cidr        = "0.0.0.0/0"
