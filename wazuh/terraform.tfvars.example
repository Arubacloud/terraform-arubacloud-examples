# ── ArubaCloud credentials ────────────────────────────────────────────────────
arubacloud_client_id     = "your-oauth2-client-id"
arubacloud_client_secret = "your-oauth2-client-secret"

# ── SSH access ────────────────────────────────────────────────────────────────
ssh_public_key = "ssh-ed25519 AAAA... user@host"

# Restrict to your management IP — Wazuh dashboard must never be public
# ssh_cidr   = "203.0.113.42/32"
# admin_cidr = "203.0.113.42/32"
# agent_cidr = "10.0.0.0/8"   # CIDR of your monitored infrastructure

# ── Wazuh ─────────────────────────────────────────────────────────────────────
# Password must contain uppercase, lowercase, digit, and special character
admin_password = "Ch@ngeMe2024!"

