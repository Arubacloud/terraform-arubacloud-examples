# ── Required: ArubaCloud credentials ──────────────────────────────────────────
arubacloud_client_id     = "your-oauth2-client-id"
arubacloud_client_secret = "your-oauth2-client-secret"

# ── SSH access (optional — a demo key is provided by default) ─────────────────
# ssh_public_key = "ssh-ed25519 AAAA... user@host"

# IMPORTANT: Restrict both CIDRs to your management IP in production.
# Adminer must never be accessible from the public internet.
# ssh_cidr   = "203.0.113.42/32"
# admin_cidr = "203.0.113.42/32"

# ── Database ──────────────────────────────────────────────────────────────────
# NOTE: The ArubaCloud DBaaS API stores the base64 of db_admin_password as the
# MySQL password. After apply, run: terraform output -raw db_admin_password_mysql
# to get the value to enter in the Adminer login form.

# db_admin_password = "K7m@P4z!L9"   # default — change for production
# db_admin_user     = "dbadmin"
# db_name           = "adminer"
# dbaas_flavor      = "DBO2A8"
# db_storage_gb     = 20

# ── Infrastructure (optional overrides) ───────────────────────────────────────
# app_name        = "adminer"
# environment     = "prod"
# location        = "ITBG-Bergamo"
# zone            = "ITBG-1"
# vm_flavor       = "CSO1A2"
# vm_disk_size_gb = 20
# billing_period  = "Hour"
# adminer_version = "4.8.1"
