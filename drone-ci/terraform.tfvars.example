# ── ArubaCloud credentials ────────────────────────────────────────────────────
arubacloud_client_id     = "your-oauth2-client-id"
arubacloud_client_secret = "your-oauth2-client-secret"

# ── SSH access ────────────────────────────────────────────────────────────────
ssh_public_key = "ssh-ed25519 AAAA... user@host"
# ssh_cidr = "203.0.113.42/32"

# ── Drone CI / Gitea integration ──────────────────────────────────────────────
# Prerequisites:
# 1. A running Gitea instance (see gitea/ example)
# 2. Create OAuth2 app in Gitea: Settings → Applications → OAuth2 Applications
#    Redirect URI: http://<drone-elastic-ip>/login
#    (Run terraform apply once without these values to get the IP, then fill in)

gitea_url           = "http://your-gitea-ip:3000"
gitea_client_id     = "your-gitea-oauth2-client-id"
gitea_client_secret = "your-gitea-oauth2-client-secret"
drone_rpc_secret    = "replace-with-openssl-rand-hex-16-output"
drone_admin_user    = "your-gitea-username"

# ── Infrastructure (optional overrides) ───────────────────────────────────────
# app_name        = "drone"
# environment     = "prod"
# location        = "ITBG-Bergamo"
# zone            = "ITBG-1"
# vm_flavor       = "CSO2A4"
# vm_disk_size_gb = 40
# billing_period  = "Hour"
# web_cidr        = "0.0.0.0/0"
